<?xml version="1.0" encoding="UTF-8"?>
<kml xmlns="http://www.opengis.net/kml/2.2">
  <Document>
    <name>Horner Shelter Investigation - Revised Terrain Model</name>
    <description>Revised terrain model for the Horner Shelter Investigation using supplied CalTopo coordinates, overhang targets, seep line, tactical travel bench, and bounded search polygons.</description>

    <Style id="style-waypoint">
      <IconStyle>
        <scale>1.15</scale>
        <Icon>
          <href>http://maps.google.com/mapfiles/kml/paddle/wht-blank.png</href>
        </Icon>
      </IconStyle>
      <LabelStyle>
        <scale>0.9</scale>
      </LabelStyle>
    </Style>

    <Style id="style-overhang">
      <IconStyle>
        <scale>1.25</scale>
        <Icon>
          <href>http://maps.google.com/mapfiles/kml/paddle/red-stars.png</href>
        </Icon>
      </IconStyle>
      <LabelStyle>
        <scale>0.9</scale>
      </LabelStyle>
    </Style>

    <Style id="style-yellow-line">
      <LineStyle>
        <color>ff00ffff</color>
        <width>4</width>
      </LineStyle>
    </Style>

    <Style id="style-blue-line">
      <LineStyle>
        <color>ffff0000</color>
        <width>4</width>
      </LineStyle>
    </Style>

    <Style id="style-corridor">
      <LineStyle>
        <color>ff00ffff</color>
        <width>2</width>
      </LineStyle>
      <PolyStyle>
        <color>1a00ffff</color>
        <fill>1</fill>
        <outline>1</outline>
      </PolyStyle>
    </Style>

    <Style id="style-bluff-zone">
      <LineStyle>
        <color>ffffff99</color>
        <width>2</width>
      </LineStyle>
      <PolyStyle>
        <color>1aff0000</color>
        <fill>1</fill>
        <outline>1</outline>
      </PolyStyle>
    </Style>



    <Style id="style-gate">
      <IconStyle>
        <scale>1.25</scale>
        <Icon>
          <href>http://maps.google.com/mapfiles/kml/paddle/orange-circle.png</href>
        </Icon>
      </IconStyle>
      <LabelStyle>
        <scale>0.9</scale>
      </LabelStyle>
    </Style>

    <Style id="style-moore-homestead">
      <IconStyle>
        <scale>1.20</scale>
        <Icon>
          <href>http://maps.google.com/mapfiles/kml/paddle/grn-circle.png</href>
        </Icon>
      </IconStyle>
      <LabelStyle>
        <scale>0.9</scale>
      </LabelStyle>
    </Style>

    <Style id="style-access-line">
      <LineStyle>
        <color>ffaaaaaa</color>
        <width>3</width>
      </LineStyle>
    </Style>

    <Folder>
      <name>Waypoints</name>
    <Placemark>
      <name>Spencer Horner Home Site (Baseline: ~1,186 ft)</name>
      <description>Starting elevation baseline. Track the 1,180–1,200 ft contour band from this point to maintain the tactical side-slope traverse.</description>
      <styleUrl>#style-waypoint</styleUrl>
      <Point>
        <coordinates>-93.49817000,35.66817000,0</coordinates>
      </Point>
    </Placemark>
    <Placemark>
      <name>Spencer Horner Cemetery</name>
      
      <styleUrl>#style-waypoint</styleUrl>
      <Point>
        <coordinates>-93.49550000,35.66217000,0</coordinates>
      </Point>
    </Placemark>
    <Placemark>
      <name>Primary Overhang Target A (North)</name>
      <description>High-probability structural alcove. Scout for deep sandstone caprock undercuts and backward-bowing cliff faces.</description>
      <styleUrl>#style-overhang</styleUrl>
      <Point>
        <coordinates>-93.48930000,35.65885000,0</coordinates>
      </Point>
    </Placemark>
    <Placemark>
      <name>Primary Overhang Target B (South)</name>
      <description>High-probability structural alcove near the lower drainage entry point. Check for natural visual screening from giant talus blocks.</description>
      <styleUrl>#style-overhang</styleUrl>
      <Point>
        <coordinates>-93.48850000,35.65790000,0</coordinates>
      </Point>
    </Placemark>
    </Folder>

    <Folder>
      <name>Access and Context Points</name>
      <Placemark>
        <name>Locked Gate / Cable — Primary (Jimmie SSE, Confirmed)</name>
        <description>GIS corridor scan confirmed 17 Jun 2026. Federal boundary crossing on NW-fork dirt spur ≈0.9 mi SSE of Moore Cemetery. PPAN 001-03571-000 — U.S.A., 621 ac, Sec. 31 T12N R23W. South-side parcel at boundary: 001-06435-000 (U.S.A., 240 ac, S25). Source: AGISO CAMA / Johnson assessor feed.</description>
        <styleUrl>#style-gate</styleUrl>
        <Point>
          <coordinates>-93.48564000,35.66075000,0</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>Locked Gate / Cable — Legacy KML Estimate (Discard)</name>
        <description>Troy-era unverified estimate on -93.4955 meridian. PPAN 001-06521-000 — GALLOWAY LAND CO LLC. Not Jimmie-corrected; do not use for navigation.</description>
        <styleUrl>#style-gate</styleUrl>
        <Point>
          <coordinates>-93.49550000,35.64768000,0</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>Moore Homestead / Old Moore Place (Approx. Field-Check)</name>
        <description>Approximate contextual placement for the Moore homestead / old Moore place, set between the locked cable access and Moore Cemetery along the likely approach corridor. Field GPS should replace this estimated coordinate if an exact homestead point is confirmed.</description>
        <styleUrl>#style-moore-homestead</styleUrl>
        <Point>
          <coordinates>-93.49550000,35.65638000,0</coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>Access Context Route — Primary Gate to Moore Cemetery (Jimmie SSE)</name>
        <description>Primary access corridor from confirmed federal gate boundary (35.66075, -93.48564) northwest to Moore Cemetery (35.6666, -93.4955). Field-check road alignment against satellite imagery.</description>
        <styleUrl>#style-access-line</styleUrl>
        <LineString>
          <tessellate>1</tessellate>
          <coordinates>
            -93.48564000,35.66075000,0
            -93.49260000,35.66488000,0
            -93.49550000,35.66660000,0
          </coordinates>
        </LineString>
      </Placemark>
    </Folder>

    <Folder>
      <name>Trails and Polylines</name>
    <Placemark>
      <name>Tactical Travel Bench (Contour Route)</name>
      <description>Concealed side-slope route. Follows the topographic grain along the 1,180–1,200 ft contours to avoid open valley floors and steep crests.</description>
      <styleUrl>#style-yellow-line</styleUrl>
      <LineString>
        <tessellate>1</tessellate>
        <coordinates>
              -93.49817000,35.66817000,0
              -93.49550000,35.66217000,0
              -93.48883000,35.65833000,0
        </coordinates>
      </LineString>
    </Placemark>
    <Placemark>
      <name>Sandstone/Shale Seep Line</name>
      <description>Hydrological contact zone. Trace this exact seam to locate wet-weather trickles or active spring seeps emerging at the sandstone/shale junction.</description>
      <styleUrl>#style-blue-line</styleUrl>
      <LineString>
        <tessellate>1</tessellate>
        <coordinates>
              -93.48945000,35.65910000,0
              -93.48883000,35.65833000,0
              -93.48810000,35.65750000,0
        </coordinates>
      </LineString>
    </Placemark>
    </Folder>

    <Folder>
      <name>Search Corridors and Zones</name>
    <Placemark>
      <name>100m Wide Home-to-Bluff Corridor</name>
      <description>Maximum lateral boundaries defining the family&#x27;s concealed approach corridor.</description>
      <styleUrl>#style-corridor</styleUrl>
      <Polygon>
        <tessellate>1</tessellate>
        <outerBoundaryIs>
          <LinearRing>
            <coordinates>
              -93.49503993,35.66245684,0
              -93.48851157,35.65869837,0
              -93.48914843,35.65796163,0
              -93.49596007,35.66188316,0
              -93.49868927,35.66801612,0
              -93.49765073,35.66832388,0
              -93.49503993,35.66245684,0
            </coordinates>
          </LinearRing>
        </outerBoundaryIs>
      </Polygon>
    </Placemark>
